# Copy to `.env` for local runs (never commit `.env`).

# MongoDB (same database name as Nest API if you share data)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=orderbuddy

# Docker Compose bench stack (`docker-compose.yml`): use a separate DB name so you do not mix bench data with dev
# MONGODB_URI=mongodb://127.0.0.1:27017
# MONGODB_DB=orderbuddy_bench

# --- Payment (defaults are safe for local dev) ---
# When true, no outbound HTTP to a payment URL (fast benchmarks).
PAYMENT_GATEWAY_MOCK=true

# mock | http | emergepay
PAYMENT_PROVIDER=mock

# Generic HTTP provider: POST JSON body with amountCents, paymentMethod, externalId
# PAYMENT_GATEWAY_URL=https://example.com/pay
# PAYMENT_TIMEOUT_SECONDS=15

# Circuit breaker (outbound failures before opening)
# CIRCUIT_FAILURE_THRESHOLD=5
# CIRCUIT_OPEN_SECONDS=30

# --- Emergepay (ChargeIt Pro virtual terminal) — only when PAYMENT_PROVIDER=emergepay ---
# EMERGEPAY_ENVIRONMENT_URL=https://api.emergepay-sandbox.chargeitpro.com/virtualterminal/v1
# EMERGEPAY_CREDENTIALS_FROM_LOCATION=true
# If false, set static org credentials:
# EMERGEPAY_OID=your_oid
# EMERGEPAY_AUTH_TOKEN=your_bearer_token

# Server
# HOST=0.0.0.0
# PORT=8081
